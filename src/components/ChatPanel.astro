<!-- ChatPanel.astro — UI del chat con Gemini Nano -->
<section class="chat-panel" id="chat-panel">
  <div class="chat-header">
    <h3>Asistente IA</h3>
    <small id="chat-status">Iniciando...</small>
  </div>
  <div class="chat-messages" id="chat-messages"></div>
  <div class="chat-input-row">
    <input
      type="text"
      id="chat-input"
      placeholder="Escribe lo que quieres configurar..."
      autocomplete="off"
    />
    <button id="chat-send">Enviar</button>
  </div>
</section>

<style>
  .chat-panel {
    max-width: 900px;
    margin: 2rem auto 0;
    border: 1px solid #e0e0e0;
    border-radius: 16px;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .chat-header {
    padding: 0.75rem 1rem;
    background: #f5f5f7;
    border-bottom: 1px solid #e0e0e0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .chat-header h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .chat-header small {
    color: #86868b;
    font-size: 0.8rem;
  }

  .chat-messages {
    height: 250px;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: #fafafa;
  }

  .chat-messages:empty::before {
    content: 'Prueba: "Ponlo en negro" o "Quiero el modelo más grande"';
    color: #86868b;
    font-size: 0.9rem;
    text-align: center;
    margin: auto;
  }

  :global(.chat-msg) {
    padding: 0.5rem 0.75rem;
    border-radius: 12px;
    max-width: 80%;
    word-wrap: break-word;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  :global(.chat-user) {
    align-self: flex-end;
    background: #0071e3;
    color: white;
  }

  :global(.chat-assistant) {
    align-self: flex-start;
    background: #e8e8ed;
    color: #1d1d1f;
  }

  .chat-input-row {
    display: flex;
    border-top: 1px solid #e0e0e0;
  }

  .chat-input-row input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: none;
    outline: none;
    font-size: 0.95rem;
    background: white;
  }

  .chat-input-row input:disabled {
    background: #f5f5f7;
    color: #86868b;
  }

  .chat-input-row button {
    padding: 0.75rem 1.5rem;
    background: #0071e3;
    color: white;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    transition: background 0.2s;
  }

  .chat-input-row button:hover:not(:disabled) {
    background: #0077ed;
  }

  .chat-input-row button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
