---
import ChatPanel from './ChatPanel.astro';
---

<section class="product-container">
  <div class="status-bar">
    <small id="mcp-status">Comprobando API...</small>
  </div>

  <div class="macbook-layout">
    <div class="image-wrapper">
      <img
        id="macbook-img"
        src="https://placehold.co/500x320/6E6E73/ffffff?text=MacBook+Pro+14"
        alt="MacBook Pro 14"
      />
    </div>

    <div class="details">
      <h1 id="model-title">MacBook Pro 14"</h1>
      <p class="price" id="price-display">Desde 2.229 €</p>

      <div class="selector">
        <p>Modelo:</p>
        <div class="model-options">
          <button class="model-btn" data-model="macbookAir13">MacBook Air 13"</button>
          <button class="model-btn" data-model="macbookAir15">MacBook Air 15"</button>
          <button class="model-btn selected" data-model="macbookPro14">MacBook Pro 14"</button>
          <button class="model-btn" data-model="macbookPro16">MacBook Pro 16"</button>
        </div>
      </div>

      <div class="selector">
        <p>Color: <strong id="color-name">Gris Espacial</strong></p>
        <div class="color-options">
          <button class="color-btn" data-hex="#E3E4E5" data-name="Plata" style="background-color: #E3E4E5"></button>
          <button class="color-btn selected" data-hex="#6E6E73" data-name="Gris Espacial" style="background-color: #6E6E73"></button>
          <button class="color-btn" data-hex="#2E3642" data-name="Medianoche" style="background-color: #2E3642"></button>
          <button class="color-btn" data-hex="#F0E4D3" data-name="Estelar" style="background-color: #F0E4D3"></button>
        </div>
      </div>

      <div class="selector">
        <p>Capacidad: <strong id="capacity-name">512 GB</strong></p>
        <div class="capacity-options">
          <button class="capacity-btn" data-capacity="256">256 GB</button>
          <button class="capacity-btn selected" data-capacity="512">512 GB</button>
          <button class="capacity-btn" data-capacity="1024">1 TB</button>
          <button class="capacity-btn" data-capacity="2048">2 TB</button>
        </div>
      </div>

      <div id="order-confirmation" style="display:none;">
        <p>✅ <strong id="order-summary"></strong></p>
      </div>

      <p id="ai-response"></p>
      <div id="tool-log"></div>
    </div>
  </div>
</section>

<ChatPanel />

<style>
  .product-container { max-width: 900px; margin: 0 auto; padding: 2rem; font-family: system-ui, sans-serif; }
  .status-bar { text-align: center; margin-bottom: 2rem; color: #666; }

  .macbook-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }

  .image-wrapper img { width: 100%; max-width: 500px; border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); display: block; margin: 0 auto; transition: opacity 0.3s; }

  .details h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .price { font-size: 1.25rem; color: #666; margin-bottom: 2rem; }

  .color-options { display: flex; gap: 1rem; margin-top: 0.5rem; }
  .color-btn { width: 40px; height: 40px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: transform 0.2s; }
  .color-btn:hover { transform: scale(1.1); }
  .color-btn.selected { border-color: #0071e3; padding: 3px; background-clip: content-box; }

  .selector { margin-bottom: 1.5rem; }
  .selector > p { margin-bottom: 0.5rem; }

  .model-options { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .model-btn { padding: 0.5rem 1rem; border: 2px solid #ddd; border-radius: 12px; background: white; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; }
  .model-btn:hover { border-color: #999; }
  .model-btn.selected { border-color: #0071e3; background: #f0f7ff; font-weight: bold; }

  .capacity-options { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .capacity-btn { padding: 0.5rem 1rem; border: 2px solid #ddd; border-radius: 12px; background: white; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; }
  .capacity-btn:hover { border-color: #999; }
  .capacity-btn.selected { border-color: #0071e3; background: #f0f7ff; font-weight: bold; }

  #order-confirmation { margin-top: 1.5rem; padding: 1rem; background: #f0fdf4; border: 2px solid #22c55e; border-radius: 12px; }
  #order-confirmation p { margin: 0; color: #166534; }

  #ai-response { margin-top: 2rem; color: #666; font-style: italic; min-height: 1.2em; }
  #tool-log { margin-top: 1rem; font-size: 0.85rem; color: #888; }
  #tool-log .log-entry { padding: 0.25rem 0; border-bottom: 1px solid #eee; }
  #tool-log .log-entry .log-time { color: #aaa; margin-right: 0.5rem; }
</style>

<script>
  import { initConfigurator } from '../webmcp/macbook-configurator';
  import { initChat } from '../webmcp/chat';

  const params = new URLSearchParams(window.location.search);
  const initialModel = params.get('model') || undefined;

  const { tools } = initConfigurator({
    status: document.getElementById('mcp-status'),
    img: document.getElementById('macbook-img') as HTMLImageElement | null,
    modelTitle: document.getElementById('model-title'),
    priceDisplay: document.getElementById('price-display'),
    colorLabel: document.getElementById('color-name'),
    capacityLabel: document.getElementById('capacity-name'),
    responseEl: document.getElementById('ai-response'),
    toolLog: document.getElementById('tool-log'),
    orderConfirmation: document.getElementById('order-confirmation'),
    orderSummary: document.getElementById('order-summary'),
  }, { initialModel });

  initChat({
    messages: document.getElementById('chat-messages')!,
    input: document.getElementById('chat-input') as HTMLInputElement,
    sendBtn: document.getElementById('chat-send') as HTMLButtonElement,
    status: document.getElementById('chat-status')!,
  }, {
    productName: 'MacBook',
    tools,
  });
</script>
